---
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import CTASection from "@/components/CTASection.astro";
import DisclaimerBox from "@/components/DisclaimerBox.astro";
import FAQ from "@/components/FAQ.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { createFaqSchema, serviceSchema } from "@/content/schema";
import { pageFaqs } from "@/content/pageFaqs";
import { siteData } from "@/content/siteData";

const title = "Kontakt i zapisy — sesja regresji poprzednich wcieleń";
const description =
  "Kontakt i konsultacja w sprawie sesji regresji poprzednich wcieleń. Napisz email, zadzwoń lub wyślij wiadomość przez formularz na stronie.";
const breadcrumbs = [{ label: "Kontakt i zapisy" }];
const pageFaq = pageFaqs.contact;
---

<BaseLayout title={title} description={description} breadcrumbs={breadcrumbs} schema={[serviceSchema, createFaqSchema(pageFaq)]}>
  <main>
    <section class="relative overflow-hidden bg-vellum pb-20 text-ink">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_72%_18%,rgba(255,211,90,0.42),transparent_24rem)]"></div>
      <Breadcrumbs items={breadcrumbs} />
      <div class="container-page relative grid gap-10 pt-14 lg:grid-cols-[1fr_380px] lg:items-end">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.22em] text-gold">rozmowa przed sesją</p>
          <h1 class="mt-4 max-w-4xl font-serif text-4xl leading-tight md:text-6xl">Kontakt i konsultacja przed sesją</h1>
          <p class="mt-7 max-w-3xl text-lg leading-8 text-graphite/76">
            Jeśli regresja poprzednich wcieleń wraca do Ciebie jako temat, zacznij od krótkiej wiadomości. Możesz zapytać o przebieg sesji, dostępność, formę online albo o to, czy ta praca pasuje do Twojej sytuacji.
          </p>
          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a class="btn-primary" href="#formularz">Wyślij krótką wiadomość</a>
            <a class="btn-secondary" href={siteData.contact.whatsapp} rel="noopener noreferrer">Napisz na WhatsApp</a>
          </div>
        </div>
        <div class="threshold-panel p-6">
          <h2 class="font-serif text-3xl leading-tight">Najkrótsza droga do konsultacji</h2>
          <p class="mt-4 text-sm leading-7 text-graphite/74">
            Nie potrzebujesz długiego opisu. Napisz jedno zdanie o temacie i zostaw najwygodniejszą formę kontaktu.
          </p>
          <div class="mt-6 grid gap-3 text-sm">
            <a class="contact-link border border-gold-fill/26 bg-warm-white/72 p-4" href={siteData.contact.whatsapp} rel="noopener noreferrer">
              <span class="relative block font-semibold">WhatsApp / telefon</span>
              <span class="relative mt-1 block text-gold">{siteData.contact.phone}</span>
            </a>
            <a class="contact-link border border-gold-fill/26 bg-warm-white/72 p-4" href={siteData.contact.emailHref}>
              <span class="relative block font-semibold">Email</span>
              <span class="relative mt-1 block text-gold">{siteData.contact.email}</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-vellum py-20">
      <div class="container-page grid gap-12 lg:grid-cols-[1fr_0.9fr]">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.22em] text-gold">na tej stronie</p>
          <h2 class="font-serif text-4xl leading-tight md:text-5xl">Wyślij wiadomość i sprawdź najbliższy krok</h2>
          <div class="gold-rule mt-5"></div>
          <p class="mt-7 max-w-2xl text-base leading-8 text-graphite/78">
            Decyzja o sesji może przyjść spokojnie, ale pierwszy krok warto zrobić prosto: napisz, co Cię porusza, i wybierz kontakt zwrotny. To wystarczy, żeby ustalić, czy konsultacja i sesja mają sens.
          </p>
          <div class="mt-6 grid gap-3 border-l-2 border-gold-fill pl-5 text-sm font-semibold leading-7 text-ink/82">
            <p>Wystarczy: temat, imię i wygodna forma kontaktu.</p>
            <p>Możesz napisać zwyczajnie: „Chcę zapytać o sesję PLR, wraca do mnie temat relacji / snu / lęku”.</p>
          </div>
          <div class="mt-8 flex flex-col gap-4 sm:flex-row">
            <a class="btn-primary" href="#formularz">
              Wypełnij formularz
            </a>
            <a class="btn-secondary" href={siteData.contact.emailHref}>
              Napisz email
            </a>
            <a class="btn-plain" href={siteData.links.personal} rel="noopener noreferrer">
              MaciejRegresja.pl
            </a>
          </div>
          <div class="mt-10 grid gap-4 text-sm text-graphite/76 sm:grid-cols-2">
            <div class="border border-ink/10 bg-white/65 p-5">
              <p class="font-semibold text-ink">Telefon i WhatsApp</p>
              <p class="mt-2">
                <a class="text-gold underline underline-offset-4" href={siteData.contact.phoneHref}>{siteData.contact.phone}</a>
              </p>
              <p class="mt-2">
                <a class="text-gold underline underline-offset-4" href={siteData.contact.whatsapp} rel="noopener noreferrer">Napisz na WhatsApp</a>
              </p>
            </div>
            <div class="border border-ink/10 bg-white/65 p-5">
              <p class="font-semibold text-ink">Email</p>
              <p class="mt-2">
                <a class="text-gold underline underline-offset-4" href={siteData.contact.emailHref}>{siteData.contact.email}</a>
              </p>
              <p class="mt-2 text-graphite/70">Możesz wysłać krótkie pytanie bezpośrednio z własnej skrzynki.</p>
            </div>
          </div>
          <form id="formularz" class="premium-surface mt-10 p-6 md:p-8" action={siteData.contact.emailHref} method="post" enctype="text/plain">
            <h2 class="font-serif text-3xl leading-tight text-ink">Formularz kontaktowy</h2>
            <p class="mt-4 text-sm leading-7 text-graphite/74">
              Formularz otworzy wiadomość email do {siteData.contact.email}. W treści możesz zostawić temat, preferowaną formę kontaktu i krótki opis sprawy.
            </p>
            <div class="mt-6 grid gap-4">
              <label class="grid gap-2 text-sm font-semibold text-ink">
                Imię
                <input class="border border-gold-fill/30 bg-white px-4 py-3 text-base font-normal outline-none transition focus:border-gold" type="text" name="Imię" autocomplete="name" />
              </label>
              <label class="grid gap-2 text-sm font-semibold text-ink">
                Email lub telefon zwrotny
                <input class="border border-gold-fill/30 bg-white px-4 py-3 text-base font-normal outline-none transition focus:border-gold" type="text" name="Kontakt zwrotny" autocomplete="email" />
              </label>
              <label class="grid gap-2 text-sm font-semibold text-ink">
                Wiadomość
                <textarea class="min-h-36 border border-gold-fill/30 bg-white px-4 py-3 text-base font-normal leading-7 outline-none transition focus:border-gold" name="Wiadomość" placeholder="Napisz krótko, o co chcesz zapytać: temat sesji, forma online, dostępność, przygotowanie..." ></textarea>
              </label>
              <button class="btn-primary" type="submit">
                Przygotuj wiadomość email
              </button>
              <p class="text-xs leading-6 text-graphite/62">
                Po kliknięciu otworzy się Twoja aplikacja email z przygotowaną wiadomością do Instytutu Regresji.
              </p>
            </div>
          </form>
        </div>
        <div class="space-y-6">
          <DisclaimerBox />
          <div class="border border-gold/30 bg-bone p-8">
            <h2 class="font-serif text-3xl leading-tight">Przed kontaktem</h2>
            <p class="mt-5 text-sm leading-7 text-graphite/76">
              Zastanów się, z jakim tematem przychodzisz: relacją, snem, emocją, powtarzającym się wzorcem, pytaniem o kierunek albo zainteresowaniem metodą Brama Dusz LBL. Nie musisz mieć gotowej odpowiedzi.
            </p>
          </div>
        </div>
      </div>
    </section>
    <FAQ items={pageFaq} />
    <CTASection title="Zacznij od jednej krótkiej wiadomości" text="Napisz, z jakim tematem przychodzisz albo o co chcesz zapytać. Kontakt na tej stronie wystarczy, żeby rozpocząć rozmowę bez przekierowania na zewnętrzny formularz." />
  </main>
</BaseLayout>
