---
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import CTASection from "@/components/CTASection.astro";
import FAQ from "@/components/FAQ.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { faqItems } from "@/content/faqItems";
import { faqSchema, serviceSchema, webPageSchema } from "@/content/schema";
import { siteData } from "@/content/siteData";

const title = "FAQ — regresja poprzednich wcieleń, PLR i Brama Dusz LBL";
const description =
  "Najczęstsze pytania o regresję poprzednich wcieleń, sesję PLR, Brama Dusz LBL, przygotowanie, sesję online i bezpieczeństwo pracy.";
const breadcrumbs = [{ label: "FAQ" }];
---

<BaseLayout title={title} description={description} breadcrumbs={breadcrumbs} schema={[webPageSchema({ name: title, description, url: `${siteData.url}/faq/` }), serviceSchema, faqSchema]}>
  <main>
    <section class="subpage-hero pb-16 text-ink">
      <Breadcrumbs items={breadcrumbs} />
      <div class="container-page pt-14">
        <h1 class="max-w-4xl font-serif text-[2.5rem] leading-tight sm:text-5xl md:text-[3.5rem]">FAQ o regresji poprzednich wcieleń</h1>
        <p class="mt-7 max-w-3xl text-lg leading-8 text-graphite/78">
          Pytania, które realnie pojawiają się przed pierwszą sesją: o wiarę, obrazy, lęk, sesję online, terapię i rozróżnienie względem oficjalnego LBL.
        </p>
      </div>
    </section>
    <FAQ
      items={faqItems}
      title="Najczęstsze pytania i odpowiedzi"
      intro="Odpowiedzi są celowo konkretne: wyjaśniają przebieg, granice, przygotowanie, bezpieczeństwo i różnice między PLR a pracą między wcieleniami."
    />
    <CTASection title="Nie znalazłeś odpowiedzi na swoje pytanie?" text="Napisz przez formularz na tej stronie albo wybierz telefon, WhatsApp lub email. Najpierw możesz wyjaśnić wątpliwości, a dopiero później zdecydować o sesji." />
  </main>
</BaseLayout>
