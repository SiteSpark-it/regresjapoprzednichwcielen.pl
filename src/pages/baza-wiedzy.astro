---
import ArticleCard from "@/components/ArticleCard.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import CTASection from "@/components/CTASection.astro";
import FAQ from "@/components/FAQ.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { knowledgeArticles } from "@/content/articles";
import { createFaqSchema, itemListSchema, webPageSchema } from "@/content/schema";
import { pageFaqs } from "@/content/pageFaqs";
import { siteData } from "@/content/siteData";

const title = "Baza wiedzy o regresji poprzednich wcieleń i PLR";
const description =
  "Rzetelna baza wiedzy o regresji poprzednich wcieleń: PLR, hipnoza regresyjna, bezpieczeństwo, przygotowanie, sny, relacje i integracja.";
const breadcrumbs = [{ label: "Baza wiedzy" }];
const topics = [
  ["Czym jest regresja poprzednich wcieleń?", "Podstawy PLR, podejście duchowe i symboliczne oraz granice odpowiedzialnego języka.", "/czym-jest-regresja-poprzednich-wcielen/"],
  ["Regresja do poprzedniego życia", "Jak wygląda przebieg sesji, jak przygotować się do pracy i co zrobić po spotkaniu.", "/regresja-do-poprzedniego-zycia/"],
  ["Past life regression po polsku", "Tłumaczenie pojęcia PLR i spokojne wyjaśnienie, czym różni się od LBL.", "/past-life-regression-po-polsku/"],
  ["Regresja LBL", "Różnice wobec PLR, przebieg sesji i pytania o przestrzeń między wcieleniami.", "/brama-dusz-lbl/"],
  ["Regresja między wcieleniami", "Czym jest praca z przestrzenią między wcieleniami i kiedy warto zacząć od PLR.", "/regresja-miedzy-wcieleniami/"],
  ["Maciej Maślanka", "Opis prowadzącego, sposobu pracy, kwalifikacji i zapisu na sesję.", "/o-macieju/"],
  ["FAQ", "Najczęstsze pytania przed pierwszą sesją regresji poprzednich wcieleń.", "/faq/"]
];
const pageFaq = pageFaqs.knowledge;
const categories = ["Podstawy PLR", "Doświadczenie i znaczenie", "Relacje i wzorce", "Przygotowanie do sesji"] as const;
const articleListSchema = itemListSchema(
  knowledgeArticles.map((article) => ({
    name: article.h1,
    url: `${siteData.url}/baza-wiedzy/${article.slug}/`
  }))
);
---

<BaseLayout title={title} description={description} breadcrumbs={breadcrumbs} schema={[webPageSchema({ name: title, description, url: `${siteData.url}/baza-wiedzy/`, type: "CollectionPage" }), articleListSchema, createFaqSchema(pageFaq)]}>
  <main>
    <section class="subpage-hero pb-20 text-ink">
      <Breadcrumbs items={breadcrumbs} />
      <div class="container-page pt-14">
        <h1 class="max-w-4xl font-serif text-[2.5rem] leading-tight sm:text-5xl md:text-[3.5rem]">Baza wiedzy o regresji poprzednich wcieleń</h1>
        <p class="mt-7 max-w-3xl text-lg leading-8 text-graphite/78">
          Konkretne teksty dla osób, które chcą zrozumieć PLR, hipnozę regresyjną, regresję między wcieleniami i LBL bez sensacji, kiczu i nacisku na jedną interpretację.
        </p>
      </div>
    </section>

    <section class="bg-warm-white py-14 md:py-20">
      <div class="container-page grid gap-10 lg:grid-cols-[0.75fr_1.25fr]">
        <div>
          <h2 class="font-serif text-4xl leading-tight">Od czego zacząć?</h2>
          <div class="gold-rule mt-5"></div>
          <p class="mt-5 text-base leading-8 text-graphite/76">
            Jeśli nie znasz tematu, zacznij od podstaw PLR i opisu sesji. Jeśli interesuje Cię głębsza praca duchowa, przejdź później do regresji LBL i regresji między wcieleniami.
          </p>
        </div>
        <div>
          {topics.map(([topicTitle, text, href]) => <ArticleCard title={topicTitle} text={text} href={href} />)}
        </div>
      </div>
    </section>

    <section class="bg-bone py-14 md:py-20" aria-labelledby="artykuly-poglebiajace">
      <div class="container-page">
        <h2 id="artykuly-poglebiajace" class="font-serif text-4xl leading-tight md:text-5xl">Artykuły pogłębiające temat</h2>
        <div class="gold-rule mt-5"></div>
        <p class="mt-5 max-w-3xl text-base leading-8 text-graphite/76">
          Te teksty rozwijają pytania, które często pojawiają się przed pierwszą sesją: sceptycyzm, sny, relacje, symbole, sesja online i integracja po doświadczeniu.
        </p>
        <div class="mt-10 grid gap-12">
          {categories.map((category) => (
            <section aria-labelledby={`kategoria-${category.toLocaleLowerCase("pl").replace(/\s+/g, "-")}`}>
              <div class="flex flex-col gap-2 border-b border-gold-fill/26 pb-4 sm:flex-row sm:items-end sm:justify-between">
                <h3 id={`kategoria-${category.toLocaleLowerCase("pl").replace(/\s+/g, "-")}`} class="font-serif text-3xl leading-tight">{category}</h3>
                <p class="text-sm text-graphite/78">{knowledgeArticles.filter((article) => article.category === category).length} materiały</p>
              </div>
              <div>
                {knowledgeArticles.filter((article) => article.category === category).map((article) => (
                  <ArticleCard title={article.h1} text={article.excerpt} href={`/baza-wiedzy/${article.slug}/`} meta={article.readingTime} />
                ))}
              </div>
            </section>
          ))}
        </div>
      </div>
    </section>

    <FAQ items={pageFaq} />
    <CTASection title="Masz własny temat i nie wiesz, od czego zacząć?" text="Napisz przez formularz na tej stronie. Krótka konsultacja pomoże odróżnić ciekawość od tematu, który rzeczywiście nadaje się do spokojnej pracy regresyjnej." />
  </main>
</BaseLayout>
