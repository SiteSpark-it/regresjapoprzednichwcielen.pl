---
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import CTASection from "@/components/CTASection.astro";
import DisclaimerBox from "@/components/DisclaimerBox.astro";
import FAQ from "@/components/FAQ.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { createFaqSchema, personSchema, serviceSchema } from "@/content/schema";
import { pageFaqs } from "@/content/pageFaqs";
import { siteData } from "@/content/siteData";

const title = "Maciej Maślanka — regresja duchowa i Brama Dusz LBL";
const description =
  "Maciej Maślanka: praca z regresją duchową, regresją poprzednich wcieleń, studiowanie psychologii w Warszawie i autorska metoda Brama Dusz LBL.";
const breadcrumbs = [{ label: "O Macieju" }];
const pageFaq = pageFaqs.author;
---

<BaseLayout title={title} description={description} breadcrumbs={breadcrumbs} schema={[serviceSchema, personSchema, createFaqSchema(pageFaq)]}>
  <main>
    <section class="bg-ink pb-20 text-warm-white">
      <Breadcrumbs items={breadcrumbs} />
      <div class="container-page pt-14">
        <h1 class="max-w-4xl font-serif text-4xl leading-tight md:text-6xl">Maciej Maślanka</h1>
        <p class="mt-7 max-w-3xl text-lg leading-8 text-warm-white/75">
          Informacje o prowadzącym polecanym przez tę stronę: regresja duchowa, regresja poprzednich wcieleń i autorska metoda Brama Dusz LBL.
        </p>
      </div>
    </section>

    <section class="bg-warm-white py-20">
      <div class="container-page grid gap-12 lg:grid-cols-[minmax(0,1fr)_330px]">
        <article class="prose-site max-w-3xl text-base leading-8 text-graphite/80">
          <h2 class="text-4xl">Dlaczego warto poznać jego pracę?</h2>
          <p>
            Ta strona nie jest osobistą stroną Macieja Maślanki. Powstała jako spokojne, edukacyjne miejsce o regresji poprzednich wcieleń oraz jako rekomendacja prowadzącego, którego praca może być wartościowa dla osób szukających uważnej sesji PLR.
          </p>
          <p>
            Maciej pracuje z regresją duchową, regresją poprzednich wcieleń oraz autorską metodą Brama Dusz LBL. Ukończył szkolenia z regresji i hipnozy regresyjnej, studiuje psychologię w Warszawie i rozwija się dalej w obszarze pracy inspirowanej LBL.
          </p>

          <h2 class="text-4xl">Duchowość bez tonu guru</h2>
          <p>
            W opisie jego pracy ważne jest to, że o duszy, symbolach, snach i przewodnictwie można mówić spokojnie. Bez obietnic, bez presji i bez udawania, że prowadzący wie więcej o czyimś życiu niż sama osoba uczestnicząca w sesji. Dobra sesja powinna dawać strukturę, pytania i przestrzeń, a nie gotową doktrynę.
          </p>

          <h2 class="text-4xl">Gdzie zapisać się na sesję?</h2>
          <p>
            Kontakt w sprawie sesji jest dostępny na tej stronie przez email, telefon, WhatsApp i formularz kontaktowy. Więcej o pracy Macieja można przeczytać również na <a class="text-gold underline underline-offset-4" href={siteData.links.personal} rel="noopener noreferrer">maciejregresja.pl</a>.
          </p>
        </article>
        <aside>
          <DisclaimerBox compact />
        </aside>
      </div>
    </section>

    <FAQ items={pageFaq} />
    <CTASection title="Chcesz porozmawiać o sesji?" text="Skorzystaj z kontaktu na tej stronie. Możesz napisać wiadomość, zadzwonić albo poprosić o spokojną rozmowę przed decyzją." />
  </main>
</BaseLayout>
