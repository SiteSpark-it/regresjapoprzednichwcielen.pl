---
import ArticleCard from "@/components/ArticleCard.astro";
import CTASection from "@/components/CTASection.astro";
import ContactForm from "@/components/ContactForm.astro";
import DisclaimerBox from "@/components/DisclaimerBox.astro";
import FAQ from "@/components/FAQ.astro";
import Hero from "@/components/Hero.astro";
import ServiceCard from "@/components/ServiceCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { faqItems, snippetAnswers } from "@/content/faqItems";
import { faqSchema, organizationSchema, personSchema, serviceSchema } from "@/content/schema";
import { prioritySitelinks, siteData } from "@/content/siteData";

const title = "Regresja poprzednich wcieleń — sesja PLR online i Rzeszów";
const description =
  "Regresja poprzednich wcieleń: sesja PLR online i w Rzeszowie. Spokojna praca z obrazami, emocjami i wzorcami. Zapytaj o konsultację.";

const sessionSteps = [
  "Krótka rozmowa o intencji, granicach i tym, z czym przychodzisz.",
  "Wejście w spokojny relaks, bez utraty kontroli i bez pośpiechu.",
  "Eksploracja obrazów, emocji, symboli albo historii poprzedniego życia.",
  "Zatrzymanie się przy scenach, które mają znaczenie dla obecnego życia.",
  "Łagodne zakończenie procesu i powrót do pełnej orientacji.",
  "Omówienie doświadczenia oraz zapisanie najważniejszych wniosków."
];
---

<BaseLayout title={title} description={description} schema={[organizationSchema, personSchema, serviceSchema, faqSchema]}>
  <main>
    <Hero
      title="Regresja poprzednich wcieleń — podróż do historii duszy"
      subtitle="Sesja PLR i LBL online oraz stacjonarnie w Rzeszowie dla osób, które chcą zrozumieć obrazy, emocje, sny, relacje i powracające wzorce związane z poprzednimi wcieleniami."
    />

    <section class="bg-vellum py-16" aria-labelledby="najwazniejsze-tematy">
      <div class="container-page">
        <div class="grid gap-10 lg:grid-cols-[0.78fr_1.22fr] lg:items-start">
          <div>
            <h2 id="najwazniejsze-tematy" class="font-serif text-4xl leading-tight md:text-5xl">Najważniejsze tematy</h2>
            <div class="gold-rule mt-5"></div>
            <p class="mt-5 text-base leading-8 text-graphite/76">
              Jeśli jesteś tu pierwszy raz, zacznij od podstaw. Jeżeli temat już w Tobie pracuje, przejdź od razu do konsultacji i napisz w jednym zdaniu, co wraca: relacja, sen, lęk, obraz, epoka albo poczucie misji.
            </p>
            <div class="mt-7 flex flex-col gap-3 sm:flex-row">
              <a class="btn-primary" href={siteData.cta.url} data-track="topics-consultation">Zapytaj o konsultację</a>
              <a class="btn-secondary" href={siteData.contact.emailHref} data-track="topics-email">Napisz email</a>
            </div>
          </div>
          <ol class="grid gap-3 sm:grid-cols-2">
            {
              prioritySitelinks.map((item, index) => (
                <li>
                  <a class="group grid min-h-full grid-cols-[3rem_1fr] gap-4 border border-ink/10 bg-white/72 p-4 transition hover:border-gold hover:bg-white" href={item.href} data-track={`important-topic-${item.title}`}>
                    <span class="font-serif text-2xl text-gold">{String(index + 1).padStart(2, "0")}</span>
                    <span class="pt-1 text-sm font-semibold leading-6 text-ink group-hover:text-gold">{item.title}</span>
                  </a>
                </li>
              ))
            }
          </ol>
        </div>
      </div>
    </section>

    <section class="bg-warm-white py-16" aria-labelledby="kiedy-konsultacja">
      <div class="container-page">
        <div class="premium-surface grid gap-10 p-6 md:p-10 lg:grid-cols-[0.78fr_1.22fr] lg:items-center">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.22em] text-gold">sygnał do działania</p>
            <h2 id="kiedy-konsultacja" class="mt-4 font-serif text-4xl leading-tight md:text-5xl">Kiedy warto napisać już teraz?</h2>
            <p class="mt-6 text-base leading-8 text-graphite/76">
              Nie wtedy, gdy masz idealnie ułożoną historię. Wtedy, gdy temat wraca, porusza emocje i czujesz, że samo czytanie kolejnych tekstów już nie wystarcza. Konsultacja pomaga szybko ustalić, czy lepszym kierunkiem będzie PLR, regresja LBL czy spokojna rozmowa przygotowująca.
            </p>
          </div>
          <div class="grid gap-3 md:grid-cols-2">
            <article class="border border-gold-fill/24 bg-white/72 p-5">
              <h3 class="font-serif text-2xl leading-tight">Wraca ta sama relacja</h3>
              <p class="mt-3 text-sm leading-7 text-graphite/74">Masz poczucie, że więź, konflikt albo przyciąganie niosą starszy, trudny do nazwania kontekst.</p>
            </article>
            <article class="border border-gold-fill/24 bg-white/72 p-5">
              <h3 class="font-serif text-2xl leading-tight">Powtarza się sen lub obraz</h3>
              <p class="mt-3 text-sm leading-7 text-graphite/74">Wraca miejsce, epoka, scena albo symbol, który wydaje się ważniejszy niż zwykłe skojarzenie.</p>
            </article>
            <article class="border border-gold-fill/24 bg-white/72 p-5">
              <h3 class="font-serif text-2xl leading-tight">Emocja nie odpuszcza</h3>
              <p class="mt-3 text-sm leading-7 text-graphite/74">Nie chodzi o diagnozę, tylko o uważne sprawdzenie, jaką historię może nieść wewnętrzne doświadczenie.</p>
            </article>
            <article class="border border-gold-fill/24 bg-white/72 p-5">
              <h3 class="font-serif text-2xl leading-tight">Czujesz gotowość na sesję</h3>
              <p class="mt-3 text-sm leading-7 text-graphite/74">Wystarczy jedno zdanie w formularzu. Konsultacja pomoże ustalić, czy PLR jest właściwym kierunkiem.</p>
            </article>
          </div>
          <div class="lg:col-start-2">
            <a class="btn-primary w-full sm:w-auto" href={siteData.cta.url} data-track="signal-consultation">Chcę zapytać o sesję</a>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-warm-white py-14 md:py-20" id="czym-jest">
      <div class="container-page grid gap-12 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
        <div>
          <h2 class="font-serif text-3xl leading-tight sm:text-4xl md:text-5xl">Czym jest regresja poprzednich wcieleń?</h2>
          <div class="gold-rule mt-5"></div>
          <div class="mt-7 space-y-5 text-base leading-8 text-graphite/78">
            <p>
              Regresja poprzednich wcieleń, często nazywana PLR, jest spokojną sesją rozwojową i duchową. W jej trakcie pojawiają się obrazy, emocje, symbole albo historie, które można przeżywać jako poprzednie życie lub jako ważną opowieść wewnętrzną.
            </p>
            <p>
              Nie trzeba robić z tego widowiska. Czasem najważniejszy jest jeden obraz, napięcie w ciele, poczucie znanej relacji albo scena, która pomaga zobaczyć obecny wzorzec z większego dystansu.
            </p>
            <p>
              Sesja nie służy diagnozie ani leczeniu. Jest zaproszeniem do uważnej pracy z doświadczeniem: takim, jakie się pojawia, bez nacisku na konkretny wynik.
            </p>
          </div>
        </div>
        <div class="border border-gold/30 bg-bone p-6 shadow-soft md:p-8">
          <h3 class="font-serif text-2xl leading-tight text-ink md:text-3xl">Nie musisz niczego udowadniać.</h3>
          <p class="mt-5 text-base leading-8 text-graphite/78">
            Możesz potraktować sesję duchowo, symbolicznie albo psychologiczno-duchowo. Ważne jest to, co dana historia porusza w Tobie i jak można ją później spokojnie zintegrować z codziennym życiem.
          </p>
        </div>
      </div>
    </section>

    <section class="bg-vellum py-14 md:py-20" aria-labelledby="jak-rozpoznac-temat">
      <div class="container-page">
        <div class="max-w-3xl">
          <p class="text-sm font-semibold uppercase tracking-[0.22em] text-gold">zanim podejmiesz decyzję</p>
          <h2 id="jak-rozpoznac-temat" class="mt-4 font-serif text-3xl leading-tight sm:text-4xl md:text-5xl">Po czym poznać, że to może być dobry temat do regresji?</h2>
          <div class="gold-rule mt-5"></div>
          <p class="mt-5 text-base leading-8 text-graphite/76">
            Najczęściej nie zaczyna się od pewności. Zaczyna się od powracającego wrażenia: „to jest większe niż zwykłe wspomnienie”, „ta relacja porusza mnie za mocno”, „ten sen wraca od lat”, „czuję coś, czego nie umiem logicznie wyjaśnić”.
          </p>
        </div>
        <div class="mt-10 grid gap-5 lg:grid-cols-3">
          <article class="border border-gold/30 bg-white/72 p-6">
            <h3 class="font-serif text-2xl leading-tight">Gdy wraca ta sama emocja</h3>
            <p class="mt-4 text-sm leading-7 text-graphite/76">
              Lęk, smutek, poczucie winy albo tęsknota czasem pojawiają się mocniej, niż wynikałoby to z obecnej sytuacji. Sesja może pomóc sprawdzić, czy za emocją stoi symboliczna historia, obraz albo dawny wzorzec.
            </p>
          </article>
          <article class="border border-gold/30 bg-white/72 p-6">
            <h3 class="font-serif text-2xl leading-tight">Gdy relacja wydaje się „starsza”</h3>
            <p class="mt-4 text-sm leading-7 text-graphite/76">
              Nie chodzi o romantyzowanie trudnych więzi. Chodzi o spokojne zobaczenie, czy przyciąganie, konflikt, zależność albo poczucie długu niosą głębszy wzorzec, który warto zrozumieć bez oddawania własnych granic.
            </p>
          </article>
          <article class="border border-gold/30 bg-white/72 p-6">
            <h3 class="font-serif text-2xl leading-tight">Gdy sen lub symbol nie odpuszcza</h3>
            <p class="mt-4 text-sm leading-7 text-graphite/76">
              Powtarzający się obraz, miejsce, epoka, postać albo scena mogą być punktem wejścia do sesji. Nie trzeba od razu uznawać ich za dowód. Wystarczy zobaczyć, co poruszają i dokąd prowadzą.
            </p>
          </article>
        </div>
        <div class="mt-10 grid gap-6 border-l-2 border-gold-fill bg-warm-white/72 p-6 md:grid-cols-[0.9fr_1.1fr] md:p-8">
          <div>
            <h3 class="font-serif text-3xl leading-tight">Nie musisz przychodzić z gotową historią.</h3>
          </div>
          <div class="space-y-4 text-base leading-8 text-graphite/76">
            <p>
              Wystarczy jedno zdanie: „wraca do mnie temat relacji”, „mam powtarzający się sen”, „czuję lęk bez jasnej przyczyny”, „chcę zrozumieć, czy PLR jest dla mnie”. Dobra konsultacja pomaga doprecyzować temat, zamiast wymagać od Ciebie gotowej narracji.
            </p>
            <p>
              Właśnie dlatego kontakt jest dostępny tutaj: przez formularz, email, telefon i WhatsApp. Jeśli temat jest żywy, nie trzeba czytać kolejnych dziesięciu stron, żeby zrobić pierwszy, spokojny krok.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="relative overflow-hidden bg-lemon py-14 text-ink md:py-20" aria-labelledby="krotkie-odpowiedzi">
      <div class="absolute inset-y-0 left-1/2 hidden w-px bg-gold-fill/24 lg:block"></div>
      <div class="container-page">
        <div class="grid gap-12 lg:grid-cols-[0.82fr_1.18fr] lg:items-start">
          <div class="lg:sticky lg:top-8">
            <p class="text-sm font-semibold uppercase tracking-[0.22em] text-gold">krótkie odpowiedzi</p>
            <h2 id="krotkie-odpowiedzi" class="mt-4 font-serif text-3xl leading-tight sm:text-4xl md:text-5xl">Zanim wejdziesz głębiej</h2>
            <div class="gold-rule mt-5"></div>
            <p class="mt-5 text-base leading-8 text-graphite/74">
              Te odpowiedzi są krótkie celowo. Mają dać orientację bez patosu i bez wymuszania wiary w jeden sposób rozumienia doświadczenia.
            </p>
          </div>
          <div class="grid gap-4">
          {
            snippetAnswers.map((item) => (
              <article class="border-l border-gold-fill/54 bg-warm-white/72 p-6 shadow-[0_14px_34px_rgba(126,82,0,0.06)]">
                <h3 class="font-serif text-2xl leading-tight text-gold">{item.question}</h3>
                <p class="mt-4 text-sm leading-7 text-graphite/76">{item.answer}</p>
              </article>
            ))
          }
          </div>
        </div>
      </div>
    </section>

    <section class="bg-warm-white py-14 md:py-20" id="sesja">
      <div class="container-page">
        <div class="grid gap-12 lg:grid-cols-[0.78fr_1.22fr] lg:items-start">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.22em] text-gold">przebieg pracy</p>
            <h2 class="mt-4 font-serif text-3xl leading-tight sm:text-4xl md:text-5xl">Jak wygląda sesja PLR?</h2>
            <div class="gold-rule mt-5"></div>
            <p class="mt-5 text-base leading-8 text-graphite/75">
              Sesja ma prostą strukturę, ale nie jest mechanicznym scenariuszem. Prowadzenie dostosowuje się do osoby, tempa i tego, co pojawia się w doświadczeniu.
            </p>
            <div class="mt-8 border border-gold/24 bg-bone/75 p-6">
              <h3 class="font-serif text-2xl leading-tight text-ink">Najpierw bezpieczeństwo, potem eksploracja.</h3>
              <p class="mt-4 text-sm leading-7 text-graphite/76">
                Dobra sesja nie polega na poganianiu obrazów. Ważniejsze jest spokojne prowadzenie, kontakt z ciałem, możliwość zatrzymania i późniejsza integracja znaczeń.
              </p>
            </div>
          </div>
          <ol class="grid gap-0 border-y border-ink/10">
            {
              sessionSteps.map((step, index) => (
                <li class="grid gap-5 border-b border-ink/10 py-6 last:border-b-0 sm:grid-cols-[5rem_1fr]">
                  <span class="font-serif text-4xl text-gold">{String(index + 1).padStart(2, "0")}</span>
                  <p class="text-base leading-8 text-graphite/78">{step}</p>
                </li>
              ))
            }
          </ol>
        </div>
      </div>
    </section>

    <section class="bg-vellum py-14 text-ink md:py-20" id="tematy">
      <div class="container-page">
        <div class="max-w-3xl">
          <h2 class="font-serif text-3xl leading-tight sm:text-4xl md:text-5xl">Jakie tematy można eksplorować?</h2>
          <div class="gold-rule mt-5"></div>
          <p class="mt-5 text-base leading-8 text-graphite/74">
            Regresja do poprzedniego życia bywa pomocna wtedy, gdy wraca pytanie: dlaczego ta relacja, emocja albo symbol są dla mnie tak silne?
          </p>
        </div>
        <div class="mt-10 grid gap-4 md:grid-cols-2 lg:mt-12 lg:grid-cols-3 lg:gap-5">
          <ServiceCard title="Relacje i więzi" icon="relations" text="Silne przyciąganie, powtarzające się role, dawne zobowiązania albo poczucie, że dana relacja niesie starszą historię." />
          <ServiceCard title="Lęki i napięcia" icon="heart" text="Emocje, które pojawiają się bez oczywistej przyczyny i proszą raczej o uważność niż szybką etykietę." />
          <ServiceCard title="Wzorce i schematy" icon="cycle" text="Decyzje, reakcje i wewnętrzne role, które wracają mimo prób zmiany na poziomie samej analizy." />
          <ServiceCard title="Sny i symbole" icon="dream" text="Miejsca, postacie, epoki lub obrazy, które powracają w snach, medytacji albo intuicyjnych skojarzeniach." />
          <ServiceCard title="Poczucie misji" icon="compass" text="Pytania o kierunek, talenty, sens doświadczeń i spokojne rozpoznanie tego, co naprawdę woła o uwagę." />
          <ServiceCard title="Historia duszy" icon="path" text="Szukanie szerszego kontekstu dla tego, kim jesteś, czego się uczysz i co chcesz w sobie lepiej zrozumieć." />
        </div>
      </div>
    </section>

    <section class="bg-vellum py-14 md:py-20" aria-labelledby="dalej">
      <div class="container-page">
        <div class="grid gap-10 lg:grid-cols-[0.86fr_1.14fr] lg:items-center">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.22em] text-gold">jak przejść dalej</p>
            <h2 id="dalej" class="mt-4 font-serif text-3xl leading-tight sm:text-4xl md:text-5xl">Od ciekawości do rozmowy</h2>
            <div class="gold-rule mt-5"></div>
            <p class="mt-5 text-base leading-8 text-graphite/76">
              Ta strona ma pomóc nazwać temat i podjąć świadomą decyzję. Jeśli coś w opisie jest bliskie Twojemu doświadczeniu, możesz napisać krótko i zwyczajnie, a konsultacja pozwoli sprawdzić, czy sesja PLR jest właściwym kierunkiem.
            </p>
          </div>
          <div class="grid gap-4 md:grid-cols-3">
            <article class="border-t border-gold/55 bg-white/72 p-6">
              <span class="font-serif text-4xl text-gold">01</span>
              <h3 class="mt-5 font-serif text-2xl leading-tight">Przeczytaj</h3>
              <p class="mt-3 text-sm leading-7 text-graphite/76">Zacznij od opisu PLR i przebiegu sesji. Nie musisz od razu wybierać metody.</p>
            </article>
            <article class="border-t border-gold/55 bg-white/72 p-6">
              <span class="font-serif text-4xl text-gold">02</span>
              <h3 class="mt-5 font-serif text-2xl leading-tight">Nazwij temat</h3>
              <p class="mt-3 text-sm leading-7 text-graphite/76">Relacja, sen, emocja, symbol, pytanie o sens albo powracający wzorzec wystarczą jako punkt wyjścia.</p>
            </article>
            <article class="border-t border-gold/55 bg-white/72 p-6">
              <span class="font-serif text-4xl text-gold">03</span>
              <h3 class="mt-5 font-serif text-2xl leading-tight">Napisz</h3>
              <p class="mt-3 text-sm leading-7 text-graphite/76">Wyślij wiadomość z tej strony, zadzwoń albo napisz na WhatsApp, gdy poczujesz spokojną gotowość.</p>
            </article>
          </div>
        </div>
        <div class="mt-10 flex flex-col gap-3 sm:flex-row">
          <a class="btn-primary" href={siteData.cta.url} data-track="next-step-consultation">
            Zapytaj o konsultację
          </a>
          <a class="btn-secondary" href={siteData.contact.whatsapp} rel="noopener noreferrer" data-track="next-step-whatsapp">
            Napisz na WhatsApp
          </a>
          <a class="btn-plain" href={siteData.contact.emailHref} data-track="next-step-email">
            Wyślij email
          </a>
        </div>
      </div>
    </section>

    <section class="bg-bone py-14 md:py-20">
      <div class="container-page grid gap-12 lg:grid-cols-2 lg:items-center">
        <div>
          <h2 class="font-serif text-3xl leading-tight sm:text-4xl md:text-5xl">PLR a regresja LBL</h2>
          <div class="gold-rule mt-5"></div>
          <div class="mt-7 space-y-5 text-base leading-8 text-graphite/78">
            <p>
              PLR koncentruje się głównie na poprzednim wcieleniu: historii, emocjach, relacjach i scenach, które mogą mieć znaczenie dla obecnego życia.
            </p>
            <p>
              <a class="text-gold underline underline-offset-4" href="/brama-dusz-lbl/">Regresja LBL</a> idzie szerzej. Po pracy z poprzednim wcieleniem może prowadzić do doświadczenia przejścia, przestrzeni między wcieleniami, relacji duszy, wyborów i głębszego sensu aktualnych tematów. To dobry kierunek, gdy nie chodzi tylko o jedną historię, ale o większy kontekst.
            </p>
            <p>
              W Instytucie Regresji możesz zapytać zarówno o PLR, jak i o LBL. Nie musisz samodzielnie wybierać formy przed kontaktem. Wystarczy opisać temat, a w rozmowie można dobrać właściwy rodzaj sesji.
            </p>
          </div>
        </div>
        <DisclaimerBox />
      </div>
    </section>

    <section class="bg-warm-white py-14 md:py-20">
      <div class="container-page grid gap-12 lg:grid-cols-[0.88fr_1.12fr] lg:items-center">
        <div class="relative border-l border-gold/50 bg-white/72 p-8 shadow-[0_18px_55px_rgba(7,17,31,0.08)]">
          <span class="absolute -left-px top-8 h-20 w-px bg-gold-fill"></span>
          <p class="font-serif text-2xl leading-tight text-ink md:text-3xl">„Największą wartością nie była obietnica niezwykłego efektu, tylko spokojne prowadzenie, granice i przestrzeń na własne znaczenie doświadczenia.”</p>
          <p class="mt-6 text-sm leading-7 text-graphite/78">perspektywa osoby korzystającej z sesji</p>
        </div>
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.22em] text-gold">rekomendowany prowadzący</p>
          <h2 class="mt-4 font-serif text-3xl leading-tight sm:text-4xl md:text-5xl">Maciej Maślanka i Instytut Regresji</h2>
          <div class="gold-rule mt-5"></div>
          <div class="mt-7 space-y-5 text-base leading-8 text-graphite/78">
            <p>
              Ta strona opisuje regresję poprzednich wcieleń z perspektywy osoby, która interesuje się pracą duchową, psychologią i integracją doświadczeń wewnętrznych. Jeśli ktoś szuka prowadzącego, warto poznać pracę Macieja Maślanki i Instytutu Regresji.
            </p>
            <p>
