---
import ArticleCard from "@/components/ArticleCard.astro";
import CTASection from "@/components/CTASection.astro";
import DisclaimerBox from "@/components/DisclaimerBox.astro";
import FAQ from "@/components/FAQ.astro";
import Hero from "@/components/Hero.astro";
import ServiceCard from "@/components/ServiceCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { faqItems, snippetAnswers } from "@/content/faqItems";
import { faqSchema, serviceSchema } from "@/content/schema";
import { prioritySitelinks, siteData } from "@/content/siteData";

const title = "Regresja poprzednich wcieleń — sesja PLR online";
const description =
  "Regresja poprzednich wcieleń jako spokojna praca z obrazami, emocjami i historią duszy. Sesje PLR online, bez presji i obietnic.";

const sessionSteps = [
  "Krótka rozmowa o intencji, granicach i tym, z czym przychodzisz.",
  "Wejście w spokojny relaks, bez utraty kontroli i bez pośpiechu.",
  "Eksploracja obrazów, emocji, symboli albo historii poprzedniego życia.",
  "Zatrzymanie się przy scenach, które mają znaczenie dla obecnego życia.",
  "Łagodne zakończenie procesu i powrót do pełnej orientacji.",
  "Omówienie doświadczenia oraz zapisanie najważniejszych wniosków."
];
---

<BaseLayout title={title} description={description} schema={[serviceSchema, faqSchema]}>
  <main>
    <Hero
      title="Regresja poprzednich wcieleń — podróż do historii duszy"
      subtitle="Spokojna sesja regresji duchowej dla osób, które chcą przyjrzeć się obrazom, emocjom, snom, relacjom i wzorcom kojarzonym z poprzednim życiem — bez presji jednej interpretacji."
    />

    <section class="bg-vellum py-16" aria-labelledby="najwazniejsze-tematy">
      <div class="container-page">
        <div class="grid gap-10 lg:grid-cols-[0.78fr_1.22fr] lg:items-start">
          <div>
            <h2 id="najwazniejsze-tematy" class="font-serif text-4xl leading-tight md:text-5xl">Najważniejsze tematy</h2>
            <div class="gold-rule mt-5"></div>
            <p class="mt-5 text-base leading-8 text-graphite/76">
              Jeśli jesteś tu pierwszy raz, potraktuj tę listę jak spokojną ścieżkę. Najpierw zrozum, czym jest PLR, potem zobacz przebieg sesji, a dopiero później zdecyduj, czy chcesz napisać lub umówić rozmowę.
            </p>
          </div>
          <ol class="grid gap-3 sm:grid-cols-2">
            {
              prioritySitelinks.map((item, index) => (
                <li>
                  <a class="group grid min-h-full grid-cols-[3rem_1fr] gap-4 border border-ink/10 bg-white/72 p-4 transition hover:border-gold hover:bg-white" href={item.href}>
                    <span class="font-serif text-2xl text-gold">{String(index + 1).padStart(2, "0")}</span>
                    <span class="pt-1 text-sm font-semibold leading-6 text-ink group-hover:text-gold">{item.title}</span>
                  </a>
                </li>
              ))
            }
          </ol>
        </div>
      </div>
    </section>

    <section class="bg-warm-white py-20" id="czym-jest">
      <div class="container-page grid gap-12 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
        <div>
          <h2 class="font-serif text-4xl leading-tight md:text-5xl">Czym jest regresja poprzednich wcieleń?</h2>
          <div class="gold-rule mt-5"></div>
          <div class="mt-7 space-y-5 text-base leading-8 text-graphite/78">
            <p>
              Regresja poprzednich wcieleń, często nazywana PLR, jest spokojną sesją rozwojową i duchową. W jej trakcie pojawiają się obrazy, emocje, symbole albo historie, które można przeżywać jako poprzednie życie lub jako ważną opowieść wewnętrzną.
            </p>
            <p>
              Nie trzeba robić z tego widowiska. Czasem najważniejszy jest jeden obraz, napięcie w ciele, poczucie znanej relacji albo scena, która pomaga zobaczyć obecny wzorzec z większego dystansu.
            </p>
            <p>
              Sesja nie służy diagnozie ani leczeniu. Jest zaproszeniem do uważnej pracy z doświadczeniem: takim, jakie się pojawia, bez nacisku na konkretny wynik.
            </p>
          </div>
        </div>
        <div class="border border-gold/30 bg-bone p-8 shadow-soft">
          <h3 class="font-serif text-3xl leading-tight text-ink">Nie musisz niczego udowadniać.</h3>
          <p class="mt-5 text-base leading-8 text-graphite/78">
            Możesz potraktować sesję duchowo, symbolicznie albo psychologiczno-duchowo. Ważne jest to, co dana historia porusza w Tobie i jak można ją później spokojnie zintegrować z codziennym życiem.
          </p>
        </div>
      </div>
    </section>

    <section class="relative overflow-hidden bg-lemon py-20 text-ink" aria-labelledby="krotkie-odpowiedzi">
      <div class="absolute inset-y-0 left-1/2 hidden w-px bg-gold-fill/24 lg:block"></div>
      <div class="container-page">
        <div class="grid gap-12 lg:grid-cols-[0.82fr_1.18fr] lg:items-start">
          <div class="lg:sticky lg:top-8">
            <p class="text-sm font-semibold uppercase tracking-[0.22em] text-gold">krótkie odpowiedzi</p>
            <h2 id="krotkie-odpowiedzi" class="mt-4 font-serif text-4xl leading-tight md:text-5xl">Zanim wejdziesz głębiej</h2>
            <div class="gold-rule mt-5"></div>
            <p class="mt-5 text-base leading-8 text-graphite/74">
              Te odpowiedzi są krótkie celowo. Mają dać orientację bez patosu i bez wymuszania wiary w jeden sposób rozumienia doświadczenia.
            </p>
          </div>
          <div class="grid gap-4">
          {
            snippetAnswers.map((item) => (
              <article class="border-l border-gold-fill/54 bg-warm-white/72 p-6 shadow-[0_14px_34px_rgba(126,82,0,0.06)]">
                <h3 class="font-serif text-2xl leading-tight text-gold">{item.question}</h3>
                <p class="mt-4 text-sm leading-7 text-graphite/76">{item.answer}</p>
              </article>
            ))
          }
          </div>
        </div>
      </div>
    </section>

    <section class="bg-warm-white py-20" id="sesja">
      <div class="container-page">
        <div class="grid gap-12 lg:grid-cols-[0.78fr_1.22fr] lg:items-start">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.22em] text-gold">przebieg pracy</p>
            <h2 class="mt-4 font-serif text-4xl leading-tight md:text-5xl">Jak wygląda sesja PLR?</h2>
            <div class="gold-rule mt-5"></div>
            <p class="mt-5 text-base leading-8 text-graphite/75">
              Sesja ma prostą strukturę, ale nie jest mechanicznym scenariuszem. Prowadzenie dostosowuje się do osoby, tempa i tego, co pojawia się w doświadczeniu.
            </p>
            <div class="mt-8 border border-gold/24 bg-bone/75 p-6">
              <h3 class="font-serif text-2xl leading-tight text-ink">Najpierw bezpieczeństwo, potem eksploracja.</h3>
              <p class="mt-4 text-sm leading-7 text-graphite/76">
                Dobra sesja nie polega na poganianiu obrazów. Ważniejsze jest spokojne prowadzenie, kontakt z ciałem, możliwość zatrzymania i późniejsza integracja znaczeń.
              </p>
            </div>
          </div>
          <ol class="grid gap-0 border-y border-ink/10">
            {
              sessionSteps.map((step, index) => (
                <li class="grid gap-5 border-b border-ink/10 py-6 last:border-b-0 sm:grid-cols-[5rem_1fr]">
                  <span class="font-serif text-4xl text-gold">{String(index + 1).padStart(2, "0")}</span>
                  <p class="text-base leading-8 text-graphite/78">{step}</p>
                </li>
              ))
            }
          </ol>
        </div>
      </div>
    </section>

    <section class="bg-vellum py-20 text-ink" id="tematy">
      <div class="container-page">
        <div class="max-w-3xl">
          <h2 class="font-serif text-4xl leading-tight md:text-5xl">Jakie tematy można eksplorować?</h2>
          <div class="gold-rule mt-5"></div>
          <p class="mt-5 text-base leading-8 text-graphite/74">
            Regresja do poprzedniego życia bywa pomocna wtedy, gdy wraca pytanie: dlaczego ta relacja, emocja albo symbol są dla mnie tak silne?
          </p>
        </div>
        <div class="mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
          <ServiceCard title="Relacje i więzi" icon="relations" text="Silne przyciąganie, powtarzające się role, dawne zobowiązania albo poczucie, że dana relacja niesie starszą historię." />
          <ServiceCard title="Lęki i napięcia" icon="heart" text="Emocje, które pojawiają się bez oczywistej przyczyny i proszą raczej o uważność niż szybką etykietę." />
          <ServiceCard title="Wzorce i schematy" icon="cycle" text="Decyzje, reakcje i wewnętrzne role, które wracają mimo prób zmiany na poziomie samej analizy." />
          <ServiceCard title="Sny i symbole" icon="dream" text="Miejsca, postacie, epoki lub obrazy, które powracają w snach, medytacji albo intuicyjnych skojarzeniach." />
          <ServiceCard title="Poczucie misji" icon="compass" text="Pytania o kierunek, talenty, sens doświadczeń i spokojne rozpoznanie tego, co naprawdę woła o uwagę." />
          <ServiceCard title="Historia duszy" icon="path" text="Szukanie szerszego kontekstu dla tego, kim jesteś, czego się uczysz i co chcesz w sobie lepiej zrozumieć." />
        </div>
      </div>
    </section>

    <section class="bg-vellum py-20" aria-labelledby="dalej">
      <div class="container-page">
        <div class="grid gap-10 lg:grid-cols-[0.86fr_1.14fr] lg:items-center">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.22em] text-gold">jak przejść dalej</p>
            <h2 id="dalej" class="mt-4 font-serif text-4xl leading-tight md:text-5xl">Od ciekawości do rozmowy</h2>
            <div class="gold-rule mt-5"></div>
            <p class="mt-5 text-base leading-8 text-graphite/76">
              Ta strona nie ma popychać do decyzji. Ma pomóc nazwać temat i zobaczyć, czy rozmowa o sesji ma sens. Jeśli coś w opisie jest bliskie Twojemu doświadczeniu, możesz napisać krótko i zwyczajnie.
            </p>
          </div>
          <div class="grid gap-4 md:grid-cols-3">
            <article class="border-t border-gold/55 bg-white/72 p-6">
              <span class="font-serif text-4xl text-gold">01</span>
              <h3 class="mt-5 font-serif text-2xl leading-tight">Przeczytaj</h3>
              <p class="mt-3 text-sm leading-7 text-graphite/76">Zacznij od opisu PLR i przebiegu sesji. Nie musisz od razu wybierać metody.</p>
            </article>
            <article class="border-t border-gold/55 bg-white/72 p-6">
              <span class="font-serif text-4xl text-gold">02</span>
              <h3 class="mt-5 font-serif text-2xl leading-tight">Nazwij temat</h3>
              <p class="mt-3 text-sm leading-7 text-graphite/76">Relacja, sen, emocja, symbol, pytanie o sens albo powracający wzorzec wystarczą jako punkt wyjścia.</p>
            </article>
            <article class="border-t border-gold/55 bg-white/72 p-6">
              <span class="font-serif text-4xl text-gold">03</span>
              <h3 class="mt-5 font-serif text-2xl leading-tight">Napisz</h3>
              <p class="mt-3 text-sm leading-7 text-graphite/76">Wyślij wiadomość z tej strony, zadzwoń albo napisz na WhatsApp, gdy poczujesz spokojną gotowość.</p>
            </article>
          </div>
        </div>
        <div class="mt-10 flex flex-col gap-3 sm:flex-row">
          <a class="inline-flex justify-center bg-gold-fill px-7 py-4 text-sm font-bold text-ink transition hover:bg-honey" href={siteData.cta.url}>
            Umów konsultację
          </a>
          <a class="inline-flex justify-center border border-ink/18 px-7 py-4 text-sm font-bold text-ink transition hover:border-gold hover:text-gold" href={siteData.contact.whatsapp} rel="noopener noreferrer">
            Napisz na WhatsApp
          </a>
          <a class="inline-flex justify-center border border-ink/18 px-7 py-4 text-sm font-bold text-ink transition hover:border-gold hover:text-gold" href={siteData.contact.emailHref}>
            Wyślij email
          </a>
        </div>
      </div>
    </section>

    <section class="bg-bone py-20">
      <div class="container-page grid gap-12 lg:grid-cols-2 lg:items-center">
        <div>
          <h2 class="font-serif text-4xl leading-tight md:text-5xl">PLR a Brama Dusz LBL</h2>
          <div class="gold-rule mt-5"></div>
          <div class="mt-7 space-y-5 text-base leading-8 text-graphite/78">
            <p>
              PLR koncentruje się głównie na poprzednim wcieleniu: historii, emocjach, relacjach i scenach, które mogą mieć znaczenie dla obecnego życia.
            </p>
            <p>
              <a class="text-gold underline underline-offset-4" href="/brama-dusz-lbl/">Brama Dusz LBL</a> to autorska metoda regresji duchowej. Może prowadzić przez doświadczenie poprzedniego życia, symboliczne przejście i pracę z przestrzenią między wcieleniami. Jest inspirowana publikacjami dr. Michaela Newtona, ale nie jest oficjalną usługą The Michael Newton Institute.
            </p>
            <p>
              Jeśli chcesz poznać szerszy kontekst, możesz zajrzeć do materiałów informacyjnych na <a class="text-gold underline underline-offset-4" href={siteData.links.michaelNewtonOrg} rel="noopener noreferrer">michaelnewton.org</a>. W sprawie konsultacji możesz skorzystać z kontaktu na tej stronie.
            </p>
          </div>
        </div>
        <DisclaimerBox />
      </div>
    </section>

    <section class="bg-warm-white py-20">
      <div class="container-page grid gap-12 lg:grid-cols-[0.88fr_1.12fr] lg:items-center">
        <div class="relative border-l border-gold/50 bg-white/72 p-8 shadow-[0_18px_55px_rgba(7,17,31,0.08)]">
          <span class="absolute -left-px top-8 h-20 w-px bg-gold-fill"></span>
          <p class="font-serif text-3xl leading-tight text-ink">„Największą wartością nie była obietnica niezwykłego efektu, tylko spokojne prowadzenie, granice i przestrzeń na własne znaczenie doświadczenia.”</p>
          <p class="mt-6 text-sm leading-7 text-graphite/70">perspektywa osoby korzystającej z sesji</p>
        </div>
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.22em] text-gold">rekomendowany prowadzący</p>
          <h2 class="mt-4 font-serif text-4xl leading-tight md:text-5xl">Maciej Maślanka i Instytut Regresji</h2>
          <div class="gold-rule mt-5"></div>
          <div class="mt-7 space-y-5 text-base leading-8 text-graphite/78">
            <p>
              Ta strona opisuje regresję poprzednich wcieleń z perspektywy osoby, która interesuje się pracą duchową, psychologią i integracją doświadczeń wewnętrznych. Jeśli ktoś szuka prowadzącego, warto poznać pracę Macieja Maślanki i Instytutu Regresji.
            </p>
            <p>
              Maciej pracuje z regresją duchową i regresją poprzednich wcieleń, ukończył szkolenia z regresji i hipnozy regresyjnej, studiuje psychologię w Warszawie i rozwija autorską metodę Brama Dusz LBL. W opisie jego pracy ważne są spokój, granice, brak tonu guru i odpowiedzialne rozróżnienie między sesją rozwojową a terapią kliniczną.
            </p>
            <p>
              Kontakt w sprawie sesji jest dostępny na tej stronie: przez email, telefon, WhatsApp i formularz. Szerszy kontekst pracy Macieja znajdziesz na <a class="text-gold underline underline-offset-4" href={siteData.links.personal} rel="noopener noreferrer">maciejregresja.pl</a>.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-bone py-20">
      <div class="container-page">
        <div class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr]">
          <div>
            <h2 class="font-serif text-4xl leading-tight md:text-5xl">Baza wiedzy</h2>
            <div class="gold-rule mt-5"></div>
            <p class="mt-5 text-base leading-8 text-graphite/75">
              Te teksty odpowiadają na różne intencje: od pierwszego pytania „czy to dla mnie?” po różnicę między poprzednim wcieleniem a pracą między wcieleniami.
            </p>
          </div>
          <div>
            <ArticleCard title="Czym jest regresja poprzednich wcieleń?" text="Edukacyjne wyjaśnienie PLR bez presji przyjmowania jednej interpretacji." href="/czym-jest-regresja-poprzednich-wcielen/" />
            <ArticleCard title="Regresja do poprzedniego życia" text="Jak wygląda sesja, czego się spodziewać i jak przygotować się bez napięcia." href="/regresja-do-poprzedniego-zycia/" />
            <ArticleCard title="Regresja poprzednich wcieleń dla sceptyków" text="Jak podejść do sesji bez konieczności przyjmowania gotowego światopoglądu." href="/baza-wiedzy/regresja-poprzednich-wcielen-dla-sceptykow/" />
            <ArticleCard title="Symbol czy wspomnienie w sesji PLR?" text="Co zrobić, gdy doświadczenie jest obrazem, odczuciem albo niejednoznacznym znakiem." href="/baza-wiedzy/symbol-czy-wspomnienie-w-sesji-plr/" />
            <ArticleCard title="Brama Dusz LBL" text="Opis autorskiej metody, jej granic i relacji do publikacji dr. Michaela Newtona." href="/brama-dusz-lbl/" />
            <ArticleCard title="Regresja między wcieleniami" text="Czym jest praca z przestrzenią między wcieleniami i jak odróżnić ją od PLR." href="/regresja-miedzy-wcieleniami/" />
            <ArticleCard title="Past life regression po polsku" text="Polski kontekst pojęcia PLR i spokojne tłumaczenie najważniejszych terminów." href="/past-life-regression-po-polsku/" />
          </div>
        </div>
      </div>
    </section>

    <FAQ items={faqItems} />
    <CTASection title="Jeśli czujesz, że to właściwy moment, sprawdź dostępne terminy" text="Nie musisz podejmować decyzji pod wpływem chwili. Zobacz opis sesji, wróć do pytań i umów spotkanie dopiero wtedy, gdy czujesz gotowość." />
  </main>
</BaseLayout>
