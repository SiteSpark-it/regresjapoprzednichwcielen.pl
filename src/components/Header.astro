---
import { navigation, siteData } from "@/content/siteData";
---

<header class="absolute inset-x-0 top-0 z-30 border-b border-gold-fill/18 bg-warm-white/72 text-ink backdrop-blur-md">
  <nav class="container-page flex min-h-20 items-center justify-between gap-4" aria-label="Główna nawigacja">
    <a href="/" class="flex min-w-0 items-center gap-3" aria-label={`${siteData.name} - strona główna`}>
      <span class="grid h-11 w-11 shrink-0 place-items-center border border-gold-fill/70 bg-lemon/70 text-gold" aria-hidden="true">
        <svg viewBox="0 0 32 32" class="h-7 w-7" fill="none">
          <path d="M8 27V13a8 8 0 0 1 16 0v14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
          <path d="M12 27V14a4 4 0 0 1 8 0v13" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
          <path d="M6 27h20" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
        </svg>
      </span>
      <span class="max-w-48 text-sm font-semibold leading-tight tracking-wide">{siteData.name}</span>
    </a>

    <div class="hidden items-center gap-5 xl:flex">
      {
        navigation.map((item) => (
          <a class="text-xs font-medium uppercase tracking-[0.12em] text-graphite/72 transition hover:text-gold 2xl:text-[0.78rem]" href={item.href}>
            {item.label}
          </a>
        ))
      }
    </div>

    <div class="hidden items-center gap-3 xl:flex">
      <a class="text-xs font-semibold uppercase tracking-[0.12em] text-gold hover:text-ink" href={siteData.contact.emailHref}>
        Email
      </a>
      <a
        class="border border-gold-fill/70 bg-lemon/60 px-5 py-3 text-sm font-semibold text-gold transition hover:bg-gold-fill hover:text-ink"
        href={siteData.cta.url}
        rel="noopener noreferrer"
      >
        Umów rozmowę
      </a>
    </div>

    <details class="relative xl:hidden">
      <summary class="list-none border border-gold-fill/36 bg-warm-white/75 px-4 py-3 text-sm font-semibold text-ink marker:hidden">
        Menu
      </summary>
      <div class="absolute right-0 mt-3 w-72 max-w-[calc(100vw-2rem)] border border-gold-fill/24 bg-warm-white p-4 shadow-soft">
        <div class="grid gap-2">
          {
            navigation.map((item) => (
              <a class="px-2 py-2 text-sm text-graphite/82 hover:text-gold" href={item.href}>
                {item.label}
              </a>
            ))
          }
          <a class="mt-2 bg-gold-fill px-4 py-3 text-center text-sm font-bold text-ink" href={siteData.cta.url} rel="noopener noreferrer">
            Umów rozmowę
          </a>
          <a class="border border-gold-fill/28 px-4 py-3 text-center text-sm font-semibold text-ink" href={siteData.contact.emailHref}>
            Napisz email
          </a>
        </div>
      </div>
    </details>
  </nav>
</header>
