---
import { siteData } from "@/content/siteData";

interface Props {
  title?: string;
  text?: string;
}

const {
  title = "Zacznij od krótkiej konsultacji",
  text = "Wystarczy jedna wiadomość: z czym przychodzisz, czy wolisz kontakt telefoniczny, WhatsApp czy email, i czy interesuje Cię sesja online. Resztę można doprecyzować spokojnie w rozmowie."
} = Astro.props;
---

<section class="relative overflow-hidden bg-lemon py-20 text-ink">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_20%,rgba(245,181,31,0.4),transparent_22rem),linear-gradient(135deg,rgba(255,253,244,0.62),rgba(255,201,40,0.18))]"></div>
  <div class="container-page relative">
    <div class="premium-surface grid gap-10 p-6 md:p-10 lg:grid-cols-[1fr_420px] lg:items-center">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-gold">kontakt i konsultacja</p>
        <h2 class="text-balance mt-4 max-w-3xl font-serif text-4xl leading-tight md:text-5xl">{title}</h2>
        <p class="mt-6 max-w-2xl text-base leading-8 text-graphite/74">{text}</p>
        <p class="mt-5 max-w-xl text-sm font-semibold leading-7 text-ink/82">
          Najkrótsza ścieżka: kliknij konsultację, napisz jedno zdanie i wybierz najwygodniejszą formę kontaktu.
        </p>
      </div>
      <div class="grid gap-3">
        <a class="btn-primary" href={siteData.cta.url}>
          <span class="relative">Umów konsultację</span>
        </a>
        <a class="contact-link border border-gold-fill/28 bg-white/70 px-5 py-4" href={siteData.contact.whatsapp} rel="noopener noreferrer">
          <span class="relative block text-sm font-semibold">WhatsApp / telefon</span>
          <span class="relative mt-1 block text-sm text-gold">{siteData.contact.phone}</span>
        </a>
        <a class="contact-link border border-gold-fill/28 bg-white/70 px-5 py-4" href={siteData.contact.emailHref}>
          <span class="relative block text-sm font-semibold">Email</span>
          <span class="relative mt-1 block text-sm text-gold">{siteData.contact.email}</span>
        </a>
      </div>
    </div>
    <p class="mt-5 max-w-3xl text-xs leading-6 text-graphite/58">
      Sesja ma charakter rozwojowy i duchowy. Nie zastępuje diagnozy, leczenia, psychoterapii klinicznej ani konsultacji medycznej.
    </p>
  </div>
</section>
