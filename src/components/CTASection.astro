---
import { siteData } from "@/content/siteData";

interface Props {
  title?: string;
  text?: string;
}

const {
  title = "Jeśli czujesz, że to właściwy moment, zacznij od spokojnej rozmowy",
  text = "Nie trzeba mieć gotowej decyzji ani idealnie opisanej intencji. Możesz zapytać o przebieg sesji, formę spotkania i sprawdzić, czy regresja poprzednich wcieleń jest dla Ciebie właściwym kierunkiem."
} = Astro.props;
---

<section class="relative overflow-hidden bg-ink py-20 text-warm-white">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_20%,rgba(223,191,123,0.14),transparent_22rem)]"></div>
  <div class="container-page relative">
    <div class="grid gap-10 border border-gold-soft/24 bg-white/[0.035] p-6 shadow-soft md:p-10 lg:grid-cols-[1fr_420px] lg:items-center">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-gold-soft">kontakt i konsultacja</p>
        <h2 class="text-balance mt-4 max-w-3xl font-serif text-4xl leading-tight md:text-5xl">{title}</h2>
        <p class="mt-6 max-w-2xl text-base leading-8 text-warm-white/72">{text}</p>
      </div>
      <div class="grid gap-3">
        <a class="contact-link border border-gold-soft/36 bg-gold-fill px-5 py-4 text-sm font-bold text-ink" href={siteData.cta.url} rel="noopener noreferrer">
          <span class="relative">Przejdź do zapisów w Instytucie</span>
        </a>
        <a class="contact-link border border-white/12 bg-white/[0.055] px-5 py-4" href={siteData.contact.whatsapp} rel="noopener noreferrer">
          <span class="relative block text-sm font-semibold">WhatsApp / telefon</span>
          <span class="relative mt-1 block text-sm text-gold-soft">{siteData.contact.phone}</span>
        </a>
        <a class="contact-link border border-white/12 bg-white/[0.055] px-5 py-4" href={siteData.contact.emailHref}>
          <span class="relative block text-sm font-semibold">Email</span>
          <span class="relative mt-1 block text-sm text-gold-soft">{siteData.contact.email}</span>
        </a>
      </div>
    </div>
    <p class="mt-5 max-w-3xl text-xs leading-6 text-warm-white/52">
      Sesja ma charakter rozwojowy i duchowy. Nie zastępuje diagnozy, leczenia, psychoterapii klinicznej ani konsultacji medycznej.
    </p>
  </div>
</section>
