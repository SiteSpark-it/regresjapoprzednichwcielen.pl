---
import { siteData } from "@/content/siteData";

interface Props {
  title?: string;
  text?: string;
}

const {
  title = "Gotowy na spokojną podróż do historii swojej duszy?",
  text = "Umów sesję i porozmawiaj o tym, czy regresja poprzednich wcieleń jest właściwym kierunkiem pracy dla Ciebie."
} = Astro.props;
---

<section class="bg-ink py-20 text-warm-white">
  <div class="container-page grid items-center gap-8 md:grid-cols-[1fr_auto]">
    <div>
      <h2 class="max-w-3xl font-serif text-4xl leading-tight md:text-5xl">{title}</h2>
      <p class="mt-5 max-w-2xl text-base leading-8 text-warm-white/72">{text}</p>
    </div>
    <div class="md:text-right">
      <a class="inline-flex w-full justify-center bg-gold-fill px-8 py-4 text-sm font-bold text-ink transition hover:bg-gold-soft sm:w-auto" href={siteData.cta.url} rel="noopener noreferrer">
        {siteData.cta.label}
      </a>
      <p class="mt-3 max-w-xs text-xs leading-6 text-warm-white/55 md:ml-auto">
        Po kliknięciu przejdziesz do strony Instytutu Regresji z aktualną formą kontaktu i terminami.
      </p>
    </div>
  </div>
</section>
