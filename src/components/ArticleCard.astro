---
interface Props {
  title: string;
  text: string;
  href: string;
}

const { title, text, href } = Astro.props;
---

<article class="group border-t border-ink/12 py-6">
  <a href={href} class="grid gap-4 transition md:grid-cols-[1fr_auto] md:items-center">
    <div>
      <h3 class="font-serif text-2xl leading-tight text-ink transition group-hover:text-gold">{title}</h3>
      <p class="mt-3 max-w-2xl text-sm leading-7 text-graphite/75">{text}</p>
    </div>
    <span class="btn-secondary min-h-11 px-4 py-3 text-sm md:w-auto">
      Czytaj dalej
      <span aria-hidden="true" class="ml-2 transition group-hover:translate-x-1">→</span>
    </span>
  </a>
</article>
