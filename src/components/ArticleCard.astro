---
interface Props {
  title: string;
  text: string;
  href: string;
}

const { title, text, href } = Astro.props;
---

<article class="group border-t border-ink/15 py-7">
  <a href={href} class="grid gap-4 md:grid-cols-[1fr_auto] md:items-center">
    <div>
      <h3 class="font-serif text-2xl leading-tight text-ink group-hover:text-gold">{title}</h3>
      <p class="mt-3 max-w-2xl text-sm leading-7 text-graphite/75">{text}</p>
    </div>
    <span class="text-sm font-semibold text-gold">Czytaj dalej</span>
  </a>
</article>
