---
import { siteData } from "@/content/siteData";

interface Props {
  title: string;
  subtitle: string;
  image?: string;
}

const { title, subtitle, image = "/assets/hero-gateway.webp" } = Astro.props;
---

<section class="relative isolate overflow-hidden bg-ink text-warm-white lg:min-h-[760px]">
  <img
    class="absolute inset-0 h-full w-full object-cover"
    src={image}
    alt=""
    width="1600"
    height="914"
    loading="eager"
    decoding="async"
    fetchpriority="high"
  />
  <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(7,17,31,0.96)_0%,rgba(7,17,31,0.88)_37%,rgba(7,17,31,0.44)_70%,rgba(7,17,31,0.72)_100%)]"></div>
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_66%_42%,rgba(223,191,123,0.22),transparent_24rem)]"></div>
  <div class="absolute inset-x-0 bottom-0 h-36 bg-gradient-to-t from-ink to-transparent"></div>

  <div class="container-page relative grid items-center gap-8 pb-12 pt-24 lg:min-h-[760px] lg:grid-cols-[minmax(0,1fr)_380px] lg:gap-10 lg:pb-0 lg:pt-32">
    <div class="max-w-4xl py-10 md:py-16 lg:py-24">
      <div class="mb-6 flex items-center gap-4 text-[0.68rem] font-semibold uppercase tracking-[0.2em] text-gold-soft/86 sm:text-xs">
        <span class="h-px w-10 bg-gold-soft/70 sm:w-14"></span>
        spokojna praca z historią wewnętrzną
      </div>
      <h1 class="text-balance max-w-4xl font-serif text-4xl leading-[1.04] text-warm-white sm:text-5xl md:text-6xl lg:text-7xl">{title}</h1>
      <p class="mt-7 max-w-2xl text-lg leading-8 text-warm-white/82 md:text-xl">{subtitle}</p>
      <div class="mt-9 flex flex-col gap-4 sm:flex-row">
        <a class="inline-flex justify-center bg-gold-fill px-7 py-4 text-sm font-bold text-ink transition hover:bg-gold-soft" href={siteData.cta.url} rel="noopener noreferrer">
          Umów rozmowę lub sesję
        </a>
        <a class="inline-flex justify-center border border-gold-soft/60 px-7 py-4 text-sm font-bold text-gold-soft transition hover:bg-white/8" href={siteData.contact.emailHref}>
          Napisz email
        </a>
      </div>
      <dl class="mt-12 hidden max-w-3xl gap-5 border-y border-white/12 py-6 text-sm text-warm-white/72 md:grid md:grid-cols-3">
        <div>
          <dt class="font-semibold uppercase tracking-[0.18em] text-gold-soft">Forma</dt>
          <dd class="mt-2 leading-6">online oraz organizacyjnie przez Instytut Regresji</dd>
        </div>
        <div>
          <dt class="font-semibold uppercase tracking-[0.18em] text-gold-soft">Podejście</dt>
          <dd class="mt-2 leading-6">duchowe, symboliczne albo psychologiczno-duchowe</dd>
        </div>
        <div>
          <dt class="font-semibold uppercase tracking-[0.18em] text-gold-soft">Bez presji</dt>
          <dd class="mt-2 leading-6">bez obietnic leczenia i bez narzucania interpretacji</dd>
        </div>
      </dl>
    </div>

    <aside class="threshold-panel p-5 md:p-6" aria-label="Kontakt w sprawie sesji">
      <p class="text-sm font-semibold uppercase tracking-[0.22em] text-gold-soft">pierwszy krok</p>
      <h2 class="mt-4 font-serif text-3xl leading-tight text-warm-white">Porozmawiaj spokojnie, zanim podejmiesz decyzję</h2>
      <p class="mt-4 text-sm leading-7 text-warm-white/70">
        Możesz zapytać o przebieg sesji, terminy albo napisać krótko, z jakim tematem przychodzisz. Kontakt prowadzi Instytut Regresji.
      </p>
      <div class="mt-7 grid gap-3">
        <a class="contact-link border border-white/12 bg-white/[0.06] p-4" href={siteData.contact.whatsapp} rel="noopener noreferrer">
          <span class="relative block text-sm font-semibold text-warm-white">WhatsApp lub telefon</span>
          <span class="relative mt-1 block text-sm text-gold-soft">{siteData.contact.phone}</span>
        </a>
        <a class="contact-link border border-white/12 bg-white/[0.06] p-4" href={siteData.contact.emailHref}>
          <span class="relative block text-sm font-semibold text-warm-white">Email</span>
          <span class="relative mt-1 block text-sm text-gold-soft">{siteData.contact.email}</span>
        </a>
        <a class="contact-link border border-gold-soft/45 bg-gold-fill px-4 py-4 text-sm font-bold text-ink" href={siteData.cta.url} rel="noopener noreferrer">
          <span class="relative">Przejdź do zapisów w Instytucie</span>
        </a>
      </div>
      <p class="mt-5 text-xs leading-6 text-warm-white/52">
        Sesja ma charakter rozwojowy i duchowy. Nie zastępuje diagnozy, leczenia ani psychoterapii klinicznej.
      </p>
    </aside>
  </div>
</section>
