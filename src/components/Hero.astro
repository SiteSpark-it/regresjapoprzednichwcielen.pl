---
import { siteData } from "@/content/siteData";

interface Props {
  title: string;
  subtitle: string;
  image?: string;
}

const { title, subtitle, image = "/assets/hero-gateway.webp" } = Astro.props;
---

<section class="relative isolate overflow-hidden bg-vellum text-ink lg:min-h-[760px]">
  <img
    class="absolute inset-0 h-full w-full object-cover"
    src={image}
    alt=""
    width="1600"
    height="914"
    loading="eager"
    decoding="async"
    fetchpriority="high"
  />
  <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(255,253,245,0.96)_0%,rgba(255,246,220,0.9)_38%,rgba(255,227,154,0.46)_72%,rgba(255,250,240,0.78)_100%)]"></div>
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_67%_42%,rgba(255,211,90,0.38),transparent_25rem)]"></div>
  <div class="absolute inset-x-0 bottom-0 h-36 bg-gradient-to-t from-vellum to-transparent"></div>

  <div class="container-page relative grid items-center gap-8 pb-12 pt-24 lg:min-h-[760px] lg:grid-cols-[minmax(0,1fr)_380px] lg:gap-10 lg:pb-0 lg:pt-32">
    <div class="max-w-4xl py-10 md:py-16 lg:py-24">
      <div class="mb-6 flex items-center gap-4 text-[0.68rem] font-semibold uppercase tracking-[0.2em] text-gold sm:text-xs">
        <span class="h-px w-10 bg-gold-fill sm:w-14"></span>
        spokojna praca z historią wewnętrzną
      </div>
      <h1 class="text-balance max-w-4xl font-serif text-4xl leading-[1.04] text-ink sm:text-5xl md:text-6xl lg:text-7xl">{title}</h1>
      <p class="mt-7 max-w-2xl text-lg leading-8 text-graphite/82 md:text-xl">{subtitle}</p>
      <div class="mt-9 flex flex-col gap-4 sm:flex-row">
        <a class="inline-flex justify-center bg-gold-fill px-7 py-4 text-sm font-bold text-ink shadow-[0_18px_40px_rgba(242,185,47,0.28)] transition hover:bg-honey" href={siteData.cta.url} rel="noopener noreferrer">
          Umów rozmowę lub sesję
        </a>
        <a class="inline-flex justify-center border border-gold/30 bg-warm-white/70 px-7 py-4 text-sm font-bold text-gold transition hover:border-gold-fill hover:bg-lemon" href={siteData.contact.emailHref}>
          Napisz email
        </a>
      </div>
      <dl class="mt-12 hidden max-w-3xl gap-5 border-y border-gold-fill/25 py-6 text-sm text-graphite/74 md:grid md:grid-cols-3">
        <div>
          <dt class="font-semibold uppercase tracking-[0.18em] text-gold">Forma</dt>
          <dd class="mt-2 leading-6">online oraz organizacyjnie przez Instytut Regresji</dd>
        </div>
        <div>
          <dt class="font-semibold uppercase tracking-[0.18em] text-gold">Podejście</dt>
          <dd class="mt-2 leading-6">duchowe, symboliczne albo psychologiczno-duchowe</dd>
        </div>
        <div>
          <dt class="font-semibold uppercase tracking-[0.18em] text-gold">Bez presji</dt>
          <dd class="mt-2 leading-6">bez obietnic leczenia i bez narzucania interpretacji</dd>
        </div>
      </dl>
    </div>

    <aside class="threshold-panel p-5 md:p-6" aria-label="Kontakt w sprawie sesji">
      <p class="text-sm font-semibold uppercase tracking-[0.22em] text-gold">pierwszy krok</p>
      <h2 class="mt-4 font-serif text-3xl leading-tight text-ink">Porozmawiaj spokojnie, zanim podejmiesz decyzję</h2>
      <p class="mt-4 text-sm leading-7 text-graphite/72">
        Możesz zapytać o przebieg sesji, terminy albo napisać krótko, z jakim tematem przychodzisz. Kontakt prowadzi Instytut Regresji.
      </p>
      <div class="mt-7 grid gap-3">
        <a class="contact-link border border-gold-fill/26 bg-warm-white/72 p-4" href={siteData.contact.whatsapp} rel="noopener noreferrer">
          <span class="relative block text-sm font-semibold text-ink">WhatsApp lub telefon</span>
          <span class="relative mt-1 block text-sm text-gold">{siteData.contact.phone}</span>
        </a>
        <a class="contact-link border border-gold-fill/26 bg-warm-white/72 p-4" href={siteData.contact.emailHref}>
          <span class="relative block text-sm font-semibold text-ink">Email</span>
          <span class="relative mt-1 block text-sm text-gold">{siteData.contact.email}</span>
        </a>
        <a class="contact-link border border-gold-fill bg-gold-fill px-4 py-4 text-sm font-bold text-ink shadow-[0_16px_34px_rgba(242,185,47,0.28)]" href={siteData.cta.url} rel="noopener noreferrer">
          <span class="relative">Przejdź do zapisów w Instytucie</span>
        </a>
      </div>
      <p class="mt-5 text-xs leading-6 text-graphite/58">
        Sesja ma charakter rozwojowy i duchowy. Nie zastępuje diagnozy, leczenia ani psychoterapii klinicznej.
      </p>
    </aside>
  </div>
</section>
