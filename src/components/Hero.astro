---
import { siteData } from "@/content/siteData";

interface Props {
  title: string;
  subtitle: string;
  image?: string;
}

const { title, subtitle, image = "/assets/hero-gateway.webp" } = Astro.props;
---

<section class="relative isolate min-h-[720px] overflow-hidden bg-ink text-warm-white">
  <img
    class="absolute inset-0 h-full w-full object-cover"
    src={image}
    alt=""
    width="1600"
    height="914"
    loading="eager"
    decoding="async"
    fetchpriority="high"
  />
  <div class="absolute inset-0 bg-gradient-to-r from-ink via-ink/88 to-ink/18"></div>
  <div class="absolute inset-x-0 bottom-0 h-28 bg-gradient-to-t from-ink to-transparent"></div>

  <div class="container-page relative flex min-h-[720px] items-center pt-24">
    <div class="max-w-3xl py-24">
      <h1 class="max-w-full font-serif text-4xl leading-tight text-warm-white sm:text-5xl md:text-6xl lg:text-7xl">{title}</h1>
      <p class="mt-7 max-w-2xl text-lg leading-8 text-warm-white/82 md:text-xl">{subtitle}</p>
      <div class="mt-9 flex flex-col gap-4 sm:flex-row">
        <a class="inline-flex justify-center bg-gold-fill px-7 py-4 text-sm font-bold text-ink transition hover:bg-gold-soft" href={siteData.cta.url} rel="noopener noreferrer">
          {siteData.cta.label}
        </a>
        <a class="inline-flex justify-center border border-gold/70 px-7 py-4 text-sm font-bold text-gold-soft transition hover:bg-white/8" href="#czym-jest">
          {siteData.cta.secondaryLabel}
        </a>
      </div>
    </div>
  </div>
</section>
