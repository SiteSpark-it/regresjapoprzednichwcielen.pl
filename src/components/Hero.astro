---
import { siteData } from "@/content/siteData";

interface Props {
  title: string;
  subtitle: string;
  image?: string;
}

const { title, subtitle, image = "/assets/hero-gateway.webp" } = Astro.props;
---

<section class="relative isolate overflow-hidden bg-vellum text-ink lg:min-h-[720px]">
  <img
    class="absolute inset-0 h-full w-full object-cover"
    src={image}
    alt=""
    role="presentation"
    aria-hidden="true"
    width="1600"
    height="914"
    loading="eager"
    decoding="async"
    fetchpriority="high"
  />
  <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(255,254,247,0.97)_0%,rgba(255,248,223,0.92)_38%,rgba(255,220,98,0.44)_72%,rgba(255,253,244,0.74)_100%)]"></div>
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_67%_42%,rgba(255,201,40,0.44),transparent_25rem)]"></div>
  <div class="absolute inset-x-0 bottom-0 h-36 bg-gradient-to-t from-vellum to-transparent"></div>

  <div class="container-page relative grid items-center gap-8 pb-12 pt-24 lg:min-h-[720px] lg:grid-cols-[minmax(0,1fr)_380px] lg:gap-10 lg:pb-0 lg:pt-28">
    <div class="max-w-4xl py-10 md:py-16 lg:py-16">
      <div class="mb-6 flex items-center gap-4 text-[0.68rem] font-semibold uppercase tracking-[0.2em] text-gold sm:text-xs">
        <span class="h-px w-10 bg-gold-fill sm:w-14"></span>
        spokojna praca z historią wewnętrzną
      </div>
      <h1 class="text-balance max-w-4xl font-serif text-4xl leading-[1.04] text-ink sm:text-5xl md:text-6xl lg:text-7xl">{title}</h1>
      <p class="mt-7 max-w-2xl text-lg leading-8 text-graphite/82 md:text-xl">{subtitle}</p>
      <p class="mt-5 max-w-xl border-l-2 border-gold-fill pl-4 text-base font-semibold leading-7 text-ink/86">
        Jeśli temat wraca w Tobie od dłuższego czasu, zacznij od krótkiej konsultacji. Jedna wiadomość wystarczy, żeby sprawdzić najbliższy krok.
      </p>
      <div class="mt-8 grid grid-cols-1 gap-3 min-[380px]:grid-cols-2 sm:flex sm:flex-row">
        <a class="btn-primary" href={siteData.cta.url}>
          Umów konsultację
        </a>
        <a class="btn-secondary" href={siteData.contact.emailHref}>
          Napisz email
        </a>
      </div>
      <dl class="mt-8 hidden max-w-3xl gap-5 border-y border-gold-fill/25 py-4 text-sm text-graphite/74 md:grid md:grid-cols-3">
        <div>
          <dt class="font-semibold uppercase tracking-[0.18em] text-gold">Forma</dt>
          <dd class="mt-2 leading-6">kontakt przez tę stronę, email, telefon lub WhatsApp</dd>
        </div>
        <div>
          <dt class="font-semibold uppercase tracking-[0.18em] text-gold">Podejście</dt>
          <dd class="mt-2 leading-6">duchowe, symboliczne albo psychologiczno-duchowe</dd>
        </div>
        <div>
          <dt class="font-semibold uppercase tracking-[0.18em] text-gold">Bez presji</dt>
          <dd class="mt-2 leading-6">bez obietnic leczenia i bez narzucania interpretacji</dd>
        </div>
      </dl>
    </div>

    <aside class="threshold-panel p-5 md:p-6" aria-label="Kontakt w sprawie sesji">
      <p class="text-sm font-semibold uppercase tracking-[0.22em] text-gold">najprostszy krok</p>
      <h2 class="mt-4 font-serif text-3xl leading-tight text-ink">Napisz krótko. Resztę doprecyzujesz w rozmowie.</h2>
      <p class="mt-4 text-sm leading-7 text-graphite/72">
        Nie musisz opisywać całej historii. Wystarczy temat: relacja, sen, emocja, powracający wzorzec albo pytanie o sens sesji.
      </p>
      <ul class="mt-5 grid gap-2 text-sm font-semibold text-ink/82">
        <li class="flex gap-2"><span class="text-gold">01</span> kontakt bez przekierowania na inną stronę</li>
        <li class="flex gap-2"><span class="text-gold">02</span> telefon, WhatsApp, email albo formularz</li>
        <li class="flex gap-2"><span class="text-gold">03</span> spokojne ustalenie, czy sesja pasuje do tematu</li>
      </ul>
      <div class="mt-7 grid gap-3">
        <a class="contact-link border border-gold-fill/26 bg-warm-white/72 p-4" href={siteData.contact.whatsapp} rel="noopener noreferrer">
          <span class="relative block text-sm font-semibold text-ink">WhatsApp lub telefon</span>
          <span class="relative mt-1 block text-sm text-gold">{siteData.contact.phone}</span>
        </a>
        <a class="contact-link border border-gold-fill/26 bg-warm-white/72 p-4" href={siteData.contact.emailHref}>
          <span class="relative block text-sm font-semibold text-ink">Email</span>
          <span class="relative mt-1 block text-sm text-gold">{siteData.contact.email}</span>
        </a>
        <a class="btn-primary" href={siteData.cta.url}>
          <span class="relative">Przejdź do konsultacji</span>
        </a>
      </div>
      <p class="mt-5 text-xs leading-6 text-graphite/58">
        Sesja ma charakter rozwojowy i duchowy. Nie zastępuje diagnozy, leczenia ani psychoterapii klinicznej.
      </p>
    </aside>
  </div>
</section>
