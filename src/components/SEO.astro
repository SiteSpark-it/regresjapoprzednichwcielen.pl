---
import { siteData } from "@/content/siteData";
import { breadcrumbSchema, organizationSchema, personSchema, type BreadcrumbItem } from "@/content/schema";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  schema?: unknown[];
  breadcrumbs?: BreadcrumbItem[];
  noindex?: boolean;
}

const {
  title,
  description,
  canonical = new URL(Astro.url.pathname, siteData.url).toString(),
  ogTitle = title,
  ogDescription = description,
  ogImage = siteData.ogImage,
  schema = [],
  breadcrumbs = [],
  noindex = false
} = Astro.props;

const absoluteOgImage = new URL(ogImage, siteData.url).toString();
const currentUrl = new URL(Astro.url.pathname, siteData.url).toString();
const baseSchema = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: siteData.name,
    url: siteData.url,
    inLanguage: "pl-PL"
  },
  organizationSchema,
  personSchema
];

const jsonLd = [
  ...baseSchema,
  ...(!noindex ? [breadcrumbSchema(breadcrumbs, currentUrl)] : []),
  ...schema
];
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
<meta name="robots" content={noindex ? "noindex,follow" : "index,follow,max-image-preview:large"} />
<meta property="og:type" content="website" />
<meta property="og:locale" content="pl_PL" />
<meta property="og:site_name" content={siteData.name} />
<meta property="og:title" content={ogTitle} />
<meta property="og:description" content={ogDescription} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={absoluteOgImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="686" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={ogTitle} />
<meta name="twitter:description" content={ogDescription} />
<meta name="twitter:image" content={absoluteOgImage} />
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
