---
import { siteData } from "@/content/siteData";

interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

<aside class={`border-l border-gold bg-bone/80 shadow-[0_18px_45px_rgba(7,17,31,0.06)] ${compact ? "p-5" : "p-6 md:p-8"}`} aria-label="Zakres sesji">
  <p class="text-xs font-semibold uppercase tracking-[0.2em] text-gold">zakres pracy</p>
  <h2 class="mt-3 font-serif text-2xl text-ink">Sesja rozwojowa i duchowa</h2>
  <p class="mt-3 text-sm leading-7 text-graphite/78">{siteData.disclaimer}</p>
  <p class="mt-3 text-sm leading-7 text-graphite/78">
    {siteData.disclaimerNote}
  </p>
</aside>
