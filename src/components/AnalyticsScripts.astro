---
import { siteData } from "@/content/siteData";

const analyticsSite = siteData.domain;
const analyticsEndpoint = "https://instytutregresji.pl/backend/analytics.php";
const analyticsConfig = JSON.stringify({
  site: analyticsSite,
  endpoint: analyticsEndpoint,
  heartbeatMs: 15000
});
---

<script is:inline set:html={`window.IRHubConfig = ${analyticsConfig};`}></script>
<script defer src="/assets/ir-hub-track.js?v=2"></script>
