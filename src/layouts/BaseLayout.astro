---
import "@/styles/global.css";
import SEO from "@/components/SEO.astro";
import AnalyticsScripts from "@/components/AnalyticsScripts.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import StickyContactBar from "@/components/StickyContactBar.astro";
import type { BreadcrumbItem } from "@/content/schema";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  schema?: unknown[];
  breadcrumbs?: BreadcrumbItem[];
  noindex?: boolean;
}

const { title, description, canonical, ogTitle, ogDescription, ogImage, schema, breadcrumbs, noindex } = Astro.props;
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#fff1a8" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <SEO
      title={title}
      description={description}
      canonical={canonical}
      ogTitle={ogTitle}
      ogDescription={ogDescription}
      ogImage={ogImage}
      schema={schema}
      breadcrumbs={breadcrumbs}
      noindex={noindex}
    />
  </head>
  <body>
    <Header />
    <slot />
    <Footer />
    <StickyContactBar />
    <AnalyticsScripts />
  </body>
</html>
